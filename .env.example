# ─────────────────────────────────────────────────────────────────────────────
# Shree ERP — Environment template
#
# Copy this file to `.env` (which is gitignored) before running docker-compose:
#     cp .env.example .env          (macOS / Linux)
#     copy .env.example .env        (Windows cmd)
#     Copy-Item .env.example .env   (Windows PowerShell)
#
# The values below are DEMO credentials for local evaluation only.
# Change them for any real deployment, and never commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── SQL Server ──
DB_PASSWORD=ShreeErp@Str0ng!
DB_NAME=ShreeERP
DB_PORT=1434

# ── Redis ──
REDIS_PORT=6380

# ── JWT (must be at least 32 characters for HS256) ──
JWT_SECRET=ShreeERP_JWT_Super_Secret_Key_2025_Minimum32Chars_OK
JWT_ISSUER=shree-erp-api
JWT_AUDIENCE=shree-erp-client
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_DAYS=7
